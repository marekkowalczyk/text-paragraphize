#!/usr/bin/env python3.11

import sys
import argparse
import nltk
from pathlib import Path

VERSION = "1.1.0"

def ensure_nltk_data():
    """Download required NLTK data if not present."""
    try:
        nltk.data.find('tokenizers/punkt')
    except LookupError:
        try:
            nltk.download('punkt', quiet=True)
        except Exception as e:
            print(f"Error: Failed to download NLTK data: {e}", file=sys.stderr)
            sys.exit(1)

def generate_paragraphs(input_text, max_chars, language):
    """Split text into paragraphs based on character limit."""
    try:
        sentences = nltk.sent_tokenize(input_text, language=language)
    except LookupError:
        print(f"Error: Language '{language}' not supported by NLTK.", file=sys.stderr)
        print("Supported languages: czech, danish, dutch, english, estonian, finnish,", file=sys.stderr)
        print("french, german, greek, italian, norwegian, polish, portuguese, russian,", file=sys.stderr)
        print("slovene, spanish, swedish, turkish", file=sys.stderr)
        sys.exit(1)

    formatted_text = ''
    paragraph = ''

    for sentence in sentences:
        if len(paragraph) + len(sentence) < max_chars:
            paragraph += sentence + ' '
        else:
            formatted_text += paragraph.strip() + '\n\n'
            paragraph = sentence + ' '

    if paragraph:
        formatted_text += paragraph.strip() + '\n\n'

    return formatted_text.strip()

def generate_output_filename(input_path):
    """Generate output filename with -para suffix."""
    if input_path is None:
        return "output-para.md"
    p = Path(input_path)
    return str(p.parent / f"{p.stem}-para.md")

def main():
    parser = argparse.ArgumentParser(
        description='Group sentences into paragraphs based on character limit.'
    )
    parser.add_argument(
        'input_file', 
        type=str, 
        nargs='?',
        help='Path to input file (reads from stdin if omitted)'
    )
    parser.add_argument(
        '-m', '--max-chars', 
        type=int, 
        default=800, 
        help='Maximum characters per paragraph (default: 800)'
    )
    parser.add_argument(
        '-l', '--language', 
        type=str, 
        default='polish', 
        help='Language for sentence tokenization (default: polish)'
    )
    parser.add_argument(
        '-o', '--output', 
        action='store_true', 
        help='Write to Markdown file ({filename}-para.md) instead of stdout'
    )
    parser.add_argument(
        '-v', '--version', 
        action='version', 
        version=f'%(prog)s {VERSION}'
    )

    args = parser.parse_args()

    ensure_nltk_data()

    # Read input
    if args.input_file:
        try:
            with open(args.input_file, 'r', encoding='utf-8') as f:
                input_text = f.read()
        except FileNotFoundError:
            print(f"Error: File not found: {args.input_file}", file=sys.stderr)
            sys.exit(1)
        except PermissionError:
            print(f"Error: Permission denied: {args.input_file}", file=sys.stderr)
            sys.exit(1)
        except UnicodeDecodeError:
            print(f"Error: File is not valid UTF-8: {args.input_file}", file=sys.stderr)
            sys.exit(1)
    else:
        if sys.stdin.isatty():
            print("Error: No input file specified and no data on stdin.", file=sys.stderr)
            print("Usage: text-paragraphize <input_file> or pipe text to stdin.", file=sys.stderr)
            sys.exit(1)
        input_text = sys.stdin.read()

    # Process
    formatted_text = generate_paragraphs(input_text, args.max_chars, args.language)

    # Output
    if args.output:
        output_file = generate_output_filename(args.input_file)
        try:
            with open(output_file, 'w', encoding='utf-8') as f:
                f.write(formatted_text)
            print(f"Written to: {output_file}", file=sys.stderr)
        except PermissionError:
            print(f"Error: Permission denied: {output_file}", file=sys.stderr)
            sys.exit(1)
    else:
        print(formatted_text)

if __name__ == '__main__':
    main()
